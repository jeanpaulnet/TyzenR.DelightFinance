rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    
    // Auth-based Admin check (Email whitelist + Database Role check)
    // NOTE: This handles both the bootstrap admin and delegated admins.
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == "jeanpaulva@gmail.com" ||
        (exists(/databases/$(database)/documents/users_config/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users_config/$(request.auth.uid)).data.role == "Admin")
      );
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isValidAuditLog(data) {
      return data.timestamp is string
        && data.userId == request.auth.uid
        && data.action in ["CREATE", "UPDATE", "DELETE", "VIEW", "IMPORT", "EXPORT", "INVITE", "LOGIN"]
        && data.resourceType in ["business", "expense", "budget", "account", "investment", "user_config", "dashboard", "ai_assistant"];
    }

    // --- Audit Log Rules ---
    match /audit_logs/{logId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && isValidAuditLog(incoming());
      allow update, delete: if false; // Audit logs are immutable
    }

    // --- UserConfig Validation ---
    function isValidUserConfig(data) {
      return data.email is string && data.email.size() <= 200
        && data.name is string && data.name.size() <= 200
        && data.role in ['Admin', 'User']
        && data.menuAccess is map
        && data.menuAccess.keys().hasAll(['dashboard', 'transactions', 'budgets', 'ai'])
        && (data.get('createdAt', null) == null || data.createdAt is string)
        && (data.get('updatedAt', null) == null || data.updatedAt is string);
    }

    // users_config Rules
    match /users_config/{docId} {
      // Users can read any config (for search/display if needed, though usually restricted to themselves or admins)
      // Here we allow reading any to support looking up invited users by email-slug.
      allow read: if isSignedIn();
      
      allow create: if isSignedIn() && isValidUserConfig(incoming()) && (
        // Admin can create any config
        isAdmin() || 
        // User can create THEIR OWN config, but ONLY as a 'User' role
        (isOwner(docId) && incoming().role == 'User')
      );
      
      allow update: if isSignedIn() && (
        // Admin can update anything
        isAdmin() || 
        // User can update their own NAME or EMAIL, but NOT their role or menu access
        (isOwner(docId) && 
         incoming().diff(existing()).affectedKeys().hasOnly(['name', 'email', 'updatedAt']) &&
         incoming().role == existing().role &&
         incoming().menuAccess == existing().menuAccess)
      );
      
      allow delete: if isAdmin();
    }

    // --- Business Rules ---
    function isValidBusiness(data) {
      return data.name is string && data.name.size() <= 200
        && data.type in ['personal', 'business']
        && data.currency is string && data.currency.size() <= 10
        && data.timezone is string && data.timezone.size() <= 100
        && data.userId == request.auth.uid
        && (data.get('fiscalYearStart', null) == null || (data.fiscalYearStart is string && data.fiscalYearStart.size() <= 50))
        && (data.get('fiscalYearEnd', null) == null || (data.fiscalYearEnd is string && data.fiscalYearEnd.size() <= 50))
        && (data.get('createdAt', null) == null || data.createdAt is string)
        && (data.get('updatedAt', null) == null || data.updatedAt is string);
    }

    match /users/{userId}/businesses/{businessId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidBusiness(incoming());
      allow update: if isOwner(userId) && isValidBusiness(incoming()) && incoming().userId == existing().userId;
      allow delete: if isOwner(userId);
    }

    // --- Expense Rules ---
    function isValidExpense(data) {
      return data.amount is number 
        && data.category is string && data.category.size() <= 100
        && data.date is string && data.date.size() <= 50
        && data.accountId is string && data.accountId.size() <= 100
        && data.businessId is string && data.businessId.size() <= 100
        && data.userId == request.auth.uid
        && (data.get('description', null) == null || data.description is string)
        && (data.get('notes', null) == null || data.notes is string)
        && (data.get('audited', null) == null || data.audited is bool)
        && (data.get('createdAt', null) == null || data.createdAt is string)
        && (data.get('updatedAt', null) == null || data.updatedAt is string);
    }

    match /users/{userId}/expenses/{expenseId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidExpense(incoming());
      allow update: if isOwner(userId) && isValidExpense(incoming()) && incoming().userId == existing().userId;
      allow delete: if isOwner(userId);
    }

    // --- Budget Rules ---
    function isValidBudget(data) {
      return data.category is string && data.category.size() <= 100
        && data.amount is number
        && data.type in ['Income', 'Expense', 'Asset', 'Liability']
        && data.month is number && data.month >= 1 && data.month <= 12
        && data.year is number
        && data.businessId is string && data.businessId.size() <= 100
        && data.userId == request.auth.uid
        && (data.get('createdAt', null) == null || data.createdAt is string)
        && (data.get('updatedAt', null) == null || data.updatedAt is string);
    }

    match /users/{userId}/budgets/{budgetId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidBudget(incoming());
      allow update: if isOwner(userId) && isValidBudget(incoming()) && incoming().userId == existing().userId;
      allow delete: if isOwner(userId);
    }

    // --- Account Rules ---
    function isValidAccount(data) {
      return data.name is string && data.name.size() <= 100
        && data.balance is number
        && data.type in ['savings', 'checking', 'credit', 'investment']
        && data.businessId is string && data.businessId.size() <= 100
        && data.userId == request.auth.uid
        && (data.get('createdAt', null) == null || data.createdAt is string)
        && (data.get('updatedAt', null) == null || data.updatedAt is string);
    }

    match /users/{userId}/accounts/{accountId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(accountId) && isValidAccount(incoming());
      allow update: if isOwner(userId) && isValidAccount(incoming()) && incoming().userId == existing().userId;
      allow delete: if isOwner(userId);
    }

    // --- Investment Rules ---
    function isValidInvestment(data) {
      return data.symbol is string && data.symbol.size() <= 20
        && data.quantity is number
        && data.purchasePrice is number
        && data.assetClass is string && data.assetClass.size() <= 100
        && data.businessId is string && data.businessId.size() <= 100
        && data.userId == request.auth.uid
        && (data.get('createdAt', null) == null || data.createdAt is string)
        && (data.get('updatedAt', null) == null || data.updatedAt is string);
    }

    match /users/{userId}/investments/{investmentId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(investmentId) && isValidInvestment(incoming());
      allow update: if isOwner(userId) && isValidInvestment(incoming()) && incoming().userId == existing().userId;
      allow delete: if isOwner(userId);
    }
  }
}
