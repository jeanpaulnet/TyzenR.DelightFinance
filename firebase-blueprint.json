{
  "entities": {
    "Expense": {
      "title": "Expense",
      "description": "An individual expense record, stored with encrypted description and sensitive details.",
      "type": "object",
      "properties": {
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "accountId": { "type": "string" },
        "encryptedData": { "type": "string", "description": "AES-256 encrypted string containing description and other metadata." },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["amount", "category", "date", "accountId", "encryptedData", "userId", "createdAt"]
    },
    "Budget": {
      "title": "Budget",
      "description": "Budget limits for a specific category and period.",
      "type": "object",
      "properties": {
        "category": { "type": "string" },
        "amount": { "type": "number" },
        "month": { "type": "number" },
        "year": { "type": "number" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["category", "amount", "month", "year", "userId", "createdAt"]
    },
    "Account": {
      "title": "Account",
      "description": "A financial account (e.g., Savings, Credit Card).",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "balance": { "type": "number" },
        "type": { "type": "string", "enum": ["savings", "checking", "credit", "investment"] },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "balance", "type", "userId", "createdAt"]
    },
    "Investment": {
      "title": "Investment",
      "description": "Tracking of stocks, funds, or other assets.",
      "type": "object",
      "properties": {
        "symbol": { "type": "string" },
        "quantity": { "type": "number" },
        "purchasePrice": { "type": "number" },
        "assetClass": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["symbol", "quantity", "purchasePrice", "assetClass", "userId", "createdAt"]
    },
    "UserConfig": {
      "title": "User Config",
      "description": "Configuration, roles, and permissions for a user.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["Admin", "User"] },
        "menuAccess": { 
          "type": "object", 
          "properties": {
            "dashboard": { "type": "boolean" },
            "transactions": { "type": "boolean" },
            "budgets": { "type": "boolean" },
            "ai": { "type": "boolean" },
            "users": { "type": "boolean" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role", "menuAccess", "createdAt"]
    },
    "AuditLog": {
      "title": "Audit Log",
      "description": "A record of an action taken by a user within the system.",
      "type": "object",
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "userName": { "type": "string" },
        "action": { "type": "string", "enum": ["CREATE", "UPDATE", "DELETE", "VIEW", "IMPORT", "EXPORT", "INVITE", "LOGIN"] },
        "resourceType": { "type": "string", "enum": ["expense", "budget", "account", "investment", "user_config", "dashboard", "ai_assistant"] },
        "resourceId": { "type": "string" },
        "resourceName": { "type": "string" },
        "details": { "type": "string" }
      },
      "required": ["timestamp", "userId", "action", "resourceType"]
    }
  },
  "firestore": {
    "audit_logs/{logId}": {
      "schema": "AuditLog",
      "description": "System-wide audit logs."
    },
    "users_config/{userId}": {
      "schema": "UserConfig",
      "description": "Configuration and permissions for users."
    },
    "users/{userId}/expenses/{expenseId}": {
      "schema": "Expense",
      "description": "User's encrypted expenses."
    },
    "users/{userId}/budgets/{budgetId}": {
      "schema": "Budget",
      "description": "User's budgets."
    },
    "users/{userId}/accounts/{accountId}": {
      "schema": "Account",
      "description": "User's financial accounts."
    },
    "users/{userId}/investments/{investmentId}": {
      "schema": "Investment",
      "description": "User's investment holdings."
    }
  }
}
